 /* Scalable Wait Queue */
@@ -75,6 +89,33 @@ static ALWAYS_INLINE void z_priq_simple_init(sys_dlist_t *pq)
  */
 static ALWAYS_INLINE int32_t z_sched_prio_cmp(struct k_thread *thread_1, struct k_thread *thread_2)
 {
+#ifdef CONFIG_SCHED_LINUX
+	/* Class priority: DL(0) > RT(1) > CFS(2) > IDLE(3) */
+	uint8_t c1 = thread_1->base.linux_sched_class;
+	uint8_t c2 = thread_2->base.linux_sched_class;
+
+	if (c1 != c2) {
+		return (int32_t)c2 - (int32_t)c1; /* lower class value = higher prio */
+	}
+
+	/* Same class: compare within class */
+	switch (c1) {
+	case 0: /* DL: earlier deadline = higher priority */
+		if (thread_1->base.dl_deadline != thread_2->base.dl_deadline) {
+			return (thread_1->base.dl_deadline < thread_2->base.dl_deadline) ? 1 : -1;
+		}
+		return 0;
+	case 1: /* RT: higher rt_prio = higher priority */
+		return (int32_t)thread_1->base.rt_prio - (int32_t)thread_2->base.rt_prio;
+	case 2: /* CFS: lower vruntime = higher priority */
+		if (thread_1->base.vruntime != thread_2->base.vruntime) {
+			return (thread_1->base.vruntime < thread_2->base.vruntime) ? 1 : -1;
+		}
+		return 0;
+	default: /* IDLE */
+		return 0;
+	}
+#else
 	/* `prio` is <32b, so the below cannot overflow. */
 	int32_t b1 = thread_1->base.prio;
 	int32_t b2 = thread_2->base.prio;
@@ -104,6 +145,7 @@ static ALWAYS_INLINE int32_t z_sched_prio_cmp(struct k_thread *thread_1, struct
 	}
 #endif /* CONFIG_SCHED_DEADLINE */
 	return 0;
+#endif /* CONFIG_SCHED_LINUX */
 }
 
